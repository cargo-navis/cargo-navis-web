# Use the default npm registry
registry=https://registry.npmjs.org/

# Security: generate and require a lockfile on install
package-lock=true

# Security: fail if lockfile is outdated instead of silently updating it
package-lock-only=false

# Security: run install with a strict peer dependency check
strict-peer-deps=false

# Security: prevent lifecycle scripts from untrusted packages
ignore-scripts=true

# Security: always request packages over HTTPS
strict-ssl=true

# Security: exact versions by default to avoid supply-chain drift
save-exact=true

# Security: reject packages published less than 7 days ago (npm >=11.10.0)
min-release-age=7

# Security: restrict which registries can be used (no scope fallback)
fetch-retry-mintimeout=10000
fetch-retry-maxtimeout=60000

# Security: audit packages automatically on install
audit=true
audit-level=moderate

# Security: prevent npm from sending usage metrics
send-metrics=false

# Security: don't fund messages cluttering CI output
fund=false

# Engine strictness — fail if Node/npm version doesn't match engines field
engine-strict=true
